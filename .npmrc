# npm 設定。
# bun 推奨だが README にある通り npm でも入れられる構成なので、
# 同等のサプライチェーン保護を npm 側にも仕込む。
#
# minimum-release-age:
#   npm 11.5.1 で追加された install 時 age gate。単位は「分」。
#   bunfig.toml の minimumReleaseAge (秒) と同じ 7 日 = 10080 分。
# minimum-release-age-exclude:
#   age gate をバイパスする許可リスト。緊急 patch 時に追記する。
# audit:
#   install 時に npm audit を必ず走らせ、既知の advisory を出す。
# fund:
#   install ごとに表示される funding メッセージを抑止 (CI ノイズ削減)。
minimum-release-age=10080
minimum-release-age-exclude=
audit=true
fund=false
