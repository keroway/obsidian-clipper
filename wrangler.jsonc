{
  // ───────────────────────────────────────────────────────────────────────────
  // obsidian-clipper Worker
  //
  // 事前準備:
  //   1. Cloudflare アカウントにログイン:  bunx wrangler login
  //   2. R2 バケットは Remotely Save で使っているものをそのまま流用する。
  //      バケット名を下の "bucket_name" に書き込むこと。
  //   3. Vault が R2 上で "MyVault/" のような prefix を持つなら "VAULT_PREFIX"
  //      に同じ値を入れる(末尾スラッシュ必須)。prefix なしなら "" のまま。
  //   4. 共有シークレット:  bunx wrangler secret put SHARED_SECRET
  //   5. デプロイ:  bunx wrangler deploy
  // ───────────────────────────────────────────────────────────────────────────
  "name": "obsidian-clipper",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],

  "r2_buckets": [
    {
      "binding": "VAULT",
      "bucket_name": "REPLACE_WITH_YOUR_R2_BUCKET_NAME"
    }
  ],

  // Workers AI (要約) を使う場合のバインディング。
  // 使わない場合は ENABLE_SUMMARY="false" にすれば AI 呼び出しはスキップされる。
  "ai": {
    "binding": "AI"
  },

  "vars": {
    // Remotely Save のバケット内 prefix。例: "MyVault/" / 無いなら ""
    "VAULT_PREFIX": "",
    // 保存先サブフォルダ。Vault ルートからの相対パス
    "INBOX_FOLDER": "Inbox",
    // 要約を有効化するか
    "ENABLE_SUMMARY": "true",
    // 手動タグが 0 件のとき本文から LLM タグを生成するか。"true" で有効化。
    // (ホスト名 allowlist タグは本設定に関わらず常に付与される)
    // 旧名 ENABLE_AUTO_TAG (単数) も後方互換で受け付けるが、ENABLE_AUTO_TAGS を推奨。
    "ENABLE_AUTO_TAGS": "false",
    // ホスト名ベースの固定タグ allowlist。"zenn.dev:zenn,github.com:github" 形式。
    // 既定ルール (zenn/qiita/note/hatena/x/github/youtube/slides) に追記マージされる。
    "AUTO_TAGS_ALLOWLIST": "",
    // 要約に使う Workers AI モデル。日本語品質に不満が出たら別モデルへ
    "SUMMARY_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    // 要約プロバイダ。"workers-ai" (既定) または "anthropic"。
    // "anthropic" を選ぶ場合は ANTHROPIC_API_KEY を wrangler secret put で投入する。
    "SUMMARY_PROVIDER": "workers-ai",
    // Anthropic を使う場合のモデル ID。未指定なら Claude Haiku 4.5 を使用。
    "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001"
  },

  // シークレット一覧 (bunx wrangler secret put <KEY> で投入)
  //   SHARED_SECRET                — Bearer 認証トークン
  //   JINA_API_KEY                 — Jina Reader の API キー (任意)
  //   ANTHROPIC_API_KEY            — Anthropic API キー (SUMMARY_PROVIDER=anthropic 時)
  //   NOTIFY_WEBHOOK_URL           — 失敗通知先 Webhook URL (任意)。Discord/Slack 互換。
  //   CF_ACCOUNT_ID                — Cloudflare アカウント ID。Jina 失敗時の
  //                                  Browser Rendering フォールバックに使う (任意)。
  //   BROWSER_RENDERING_API_TOKEN  — Browser Rendering 実行権限のある API トークン (任意)。
  //                                  CF_ACCOUNT_ID と両方揃ったときだけフォールバックが有効。

  "observability": {
    "enabled": true
  }
}
