{
  // vitest 用の wrangler 設定。
  // メイン設定をそのまま使うと r2_buckets[0].bucket_name のプレースホルダが
  // バリデーションエラーになるため、テスト用に有効なバケット名に差し替える。
  // 実際の R2 バケットへの接続は行わない (Miniflare がローカルでモックする)。
  "name": "obsidian-clipper",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],

  "r2_buckets": [
    {
      "binding": "VAULT",
      "bucket_name": "test-vault"
    }
  ],

  "vars": {
    "VAULT_PREFIX": "",
    "INBOX_FOLDER": "Inbox",
    "ENABLE_SUMMARY": "false",
    "SUMMARY_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "SUMMARY_PROVIDER": "workers-ai",
    "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001",
    "SHARED_SECRET": "test-secret"
  }
}
